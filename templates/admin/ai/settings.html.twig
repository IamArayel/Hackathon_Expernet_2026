{% extends 'admin/base.html.twig' %}

{% block title %}Assistant IA{% endblock %}
{% block page_title %}Configuration de l'Assistant IA{% endblock %}

{% block body %}
<div class="max-w-2xl">
    <p class="text-sm text-gray-500 mb-6">
        Ces paramètres surchargent les variables d'environnement. Laisser un champ vide revient à utiliser la valeur par défaut.
    </p>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

        <div>
            {{ form_label(form.api_key, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.api_key, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
            <p class="text-xs text-gray-400 mt-1">
                Si vide, la variable d'environnement <code class="bg-gray-100 px-1 rounded">MISTRAL_API_KEY</code> est utilisée.
            </p>
            {{ form_errors(form.api_key) }}
        </div>

        <div>
            {{ form_label(form.model, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.model, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
            {{ form_errors(form.model) }}
        </div>

        <div>
            {{ form_label(form.system_prompt, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.system_prompt, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono'}}) }}
            <p class="text-xs text-gray-400 mt-1">
                Personnalisez le comportement de l'IA. Si vide, le prompt pédagogique par défaut est utilisé.
            </p>
            {{ form_errors(form.system_prompt) }}
        </div>

        <div class="pt-2">
            <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition">
                Sauvegarder la configuration
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
