{% extends 'admin/base.html.twig' %}

{% block title %}Assistant IA{% endblock %}
{% block page_title %}Configuration de l'Assistant IA{% endblock %}

{% block body %}
<div class="max-w-2xl">
    <p class="text-sm text-gray-600 mb-6">
        Ces paramètres surchargent les variables d'environnement. Laisser un champ vide revient à utiliser la valeur par défaut.
    </p>

    <div class="card-volcanic rounded-2xl p-7">
        {{ form_start(form, {attr: {class: 'space-y-6'}}) }}

        <div class="symfony-form-field">
            {{ form_label(form.api_key, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.api_key) }}
            <p class="text-xs text-gray-600 mt-2">
                Si vide, la variable d'environnement <code class="bg-smoke border border-cinder text-lava px-1.5 py-0.5 rounded text-xs font-mono">NVIDIA_API_KEY</code> est utilisée.
            </p>
            {{ form_errors(form.api_key) }}
        </div>

        <div class="symfony-form-field">
            {{ form_label(form.model, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.model) }}
            {{ form_errors(form.model) }}
        </div>

        <div class="symfony-form-field">
            {{ form_label(form.system_prompt, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.system_prompt) }}
            <p class="text-xs text-gray-600 mt-2">
                Personnalisez le comportement de l'IA. Si vide, le prompt pédagogique par défaut est utilisé.
            </p>
            {{ form_errors(form.system_prompt) }}
        </div>

        <div class="divider-lava"></div>

        <button type="submit"
                class="bg-lava text-white px-6 py-2.5 rounded-xl text-sm font-bold hover:bg-[#d44d1b] transition lava-glow-sm"
                style="font-family:'Poppins',sans-serif">
            Sauvegarder la configuration
        </button>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
