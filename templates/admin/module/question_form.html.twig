{% extends 'admin/base.html.twig' %}

{% set is_new = question.id is null %}
{% block title %}{{ is_new ? 'Nouvelle question' : 'Éditer la question' }}{% endblock %}
{% block page_title %}{{ is_new ? 'Nouvelle question' : 'Éditer la question' }}{% endblock %}

{% block body %}
<div class="flex items-center gap-2 mb-5 text-sm">
    <a href="{{ path('admin_formation_index') }}" class="text-gray-500 hover:text-lava transition">Formations</a>
    <span class="text-gray-700">/</span>
    <a href="{{ path('admin_module_index', {id: formation.id}) }}" class="text-gray-500 hover:text-lava transition">{{ formation.title }}</a>
    <span class="text-gray-700">/</span>
    <a href="{{ path('admin_question_index', {formationId: formation.id, id: module.id}) }}" class="text-gray-500 hover:text-lava transition">{{ module.title }}</a>
</div>

<div class="max-w-xl">
    <div class="card-volcanic rounded-2xl p-7">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

        <div class="symfony-form-field">
            {{ form_label(form.content, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.content) }}
            {{ form_errors(form.content) }}
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="symfony-form-field">
                {{ form_label(form.type, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
                {{ form_widget(form.type) }}
                {{ form_errors(form.type) }}
            </div>
            <div class="symfony-form-field">
                {{ form_label(form.difficulty, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
                {{ form_widget(form.difficulty) }}
                {{ form_errors(form.difficulty) }}
            </div>
        </div>

        <div class="symfony-form-field">
            {{ form_label(form.options, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.options) }}
            <p class="text-xs text-gray-600 mt-1.5">Une option par ligne. Laissez vide pour les questions ouvertes.</p>
            {{ form_errors(form.options) }}
        </div>

        <div class="symfony-form-field">
            {{ form_label(form.correctAnswer, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.correctAnswer) }}
            <p class="text-xs text-gray-600 mt-1.5">Pour un QCM, doit correspondre exactement à l'une des options.</p>
            {{ form_errors(form.correctAnswer) }}
        </div>

        <div class="divider-lava"></div>

        <button type="submit"
                class="bg-lava text-white px-6 py-2.5 rounded-xl text-sm font-bold hover:bg-[#d44d1b] transition lava-glow-sm"
                style="font-family:'Poppins',sans-serif">
            {{ is_new ? 'Créer la question' : 'Enregistrer' }}
        </button>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
