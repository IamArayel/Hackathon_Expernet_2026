{% extends 'admin/base.html.twig' %}

{% set is_new = question.id is null %}
{% block title %}{{ is_new ? 'Nouvelle question' : 'Éditer la question' }}{% endblock %}
{% block page_title %}{{ is_new ? 'Nouvelle question' : 'Éditer la question' }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4 text-sm">
    <a href="{{ path('admin_formation_index') }}" class="text-indigo-600 hover:underline">Formations</a>
    <span class="text-gray-400">/</span>
    <a href="{{ path('admin_module_index', {id: formation.id}) }}" class="text-indigo-600 hover:underline">{{ formation.title }}</a>
    <span class="text-gray-400">/</span>
    <a href="{{ path('admin_question_index', {formationId: formation.id, id: module.id}) }}" class="text-indigo-600 hover:underline">{{ module.title }}</a>
</div>

<div class="max-w-xl">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}

        <div>
            {{ form_label(form.content, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.content, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
            {{ form_errors(form.content) }}
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                {{ form_label(form.type, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.type, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
                {{ form_errors(form.type) }}
            </div>
            <div>
                {{ form_label(form.difficulty, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.difficulty, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
                {{ form_errors(form.difficulty) }}
            </div>
        </div>

        <div>
            {{ form_label(form.options, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.options, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono'}}) }}
            <p class="text-xs text-gray-400 mt-1">Une option par ligne. Laissez vide pour les questions ouvertes.</p>
            {{ form_errors(form.options) }}
        </div>

        <div>
            {{ form_label(form.correctAnswer, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.correctAnswer, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
            <p class="text-xs text-gray-400 mt-1">Pour un QCM, doit correspondre exactement à l'une des options ci-dessus.</p>
            {{ form_errors(form.correctAnswer) }}
        </div>

        <div class="pt-2">
            <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition">
                {{ is_new ? 'Créer la question' : 'Enregistrer' }}
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
