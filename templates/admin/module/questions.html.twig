{% extends 'admin/base.html.twig' %}

{% block title %}Questions — {{ module.title }}{% endblock %}
{% block page_title %}Questions de « {{ module.title }} »{% endblock %}

{% block body %}
<div class="flex items-center gap-2 mb-5 text-sm">
    <a href="{{ path('admin_formation_index') }}" class="text-gray-500 hover:text-lava transition">Formations</a>
    <span class="text-gray-700">/</span>
    <a href="{{ path('admin_module_index', {id: formation.id}) }}" class="text-gray-500 hover:text-lava transition">{{ formation.title }}</a>
    <span class="text-gray-700">/</span>
    <a href="{{ path('admin_module_edit', {formationId: formation.id, id: module.id}) }}" class="text-gray-500 hover:text-lava transition">{{ module.title }}</a>
    <div class="ml-auto">
        <a href="{{ path('admin_question_new', {formationId: formation.id, moduleId: module.id}) }}"
           class="bg-lava text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-[#d44d1b] transition lava-glow-sm"
           style="font-family:'Poppins',sans-serif">
            + Nouvelle question
        </a>
    </div>
</div>

<div class="card-volcanic rounded-2xl overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-cinder">
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Question</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Type</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Difficulté</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Bonne réponse</th>
                <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-widest text-gray-600">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-smoke">
            {% set type_labels = {mcq: 'QCM', open: 'Ouverte'} %}
            {% for question in module.questions %}
            <tr class="hover:bg-smoke transition">
                <td class="px-6 py-3 text-gray-300 max-w-xs truncate">{{ question.content }}</td>
                <td class="px-6 py-3">
                    <span class="text-xs bg-smoke text-gray-400 border border-cinder px-2.5 py-1 rounded-full">
                        {{ type_labels[question.type] ?? question.type }}
                    </span>
                </td>
                <td class="px-6 py-3 text-gray-500">{{ question.difficulty }}/3</td>
                <td class="px-6 py-3 text-gray-500 max-w-xs truncate">{{ question.correctAnswer }}</td>
                <td class="px-6 py-3 text-right">
                    <div class="flex justify-end gap-2">
                        <a href="{{ path('admin_question_edit', {formationId: formation.id, moduleId: module.id, id: question.id}) }}"
                           class="text-xs bg-lava/10 text-lava border border-lava/25 px-3 py-1.5 rounded-lg hover:bg-lava/20 transition">
                            Éditer
                        </a>
                        <form method="post" action="{{ path('admin_question_delete', {formationId: formation.id, moduleId: module.id, id: question.id}) }}"
                              onsubmit="return confirm('Supprimer cette question ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_question_' ~ question.id) }}">
                            <button class="text-xs bg-red-900/20 text-red-400 border border-red-800/40 px-3 py-1.5 rounded-lg hover:bg-red-900/40 transition">
                                Supprimer
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="px-6 py-12 text-gray-600 text-center">Aucune question</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
