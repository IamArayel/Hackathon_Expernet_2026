{% extends 'admin/base.html.twig' %}

{% set is_new = module.id is null %}
{% block title %}{{ is_new ? 'Nouveau module' : 'Éditer ' ~ module.title }}{% endblock %}
{% block page_title %}{{ is_new ? 'Nouveau module' : 'Éditer ' ~ module.title }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4 text-sm">
    <a href="{{ path('admin_formation_index') }}" class="text-indigo-600 hover:underline">Formations</a>
    <span class="text-gray-400">/</span>
    <a href="{{ path('admin_module_index', {id: formation.id}) }}" class="text-indigo-600 hover:underline">{{ formation.title }}</a>
    <span class="text-gray-400">/</span>
    <span class="text-gray-600">{{ is_new ? 'Nouveau module' : module.title }}</span>
</div>

<div class="max-w-2xl">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}

        <div>
            {{ form_label(form.title, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.title, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
            {{ form_errors(form.title) }}
        </div>

        <div>
            {{ form_label(form.position, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.position, {attr: {class: 'w-24 border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
            {{ form_errors(form.position) }}
        </div>

        <div>
            {{ form_label(form.content, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.content, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono'}}) }}
            {{ form_errors(form.content) }}
        </div>

        <div class="pt-2 flex gap-3">
            <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition">
                {{ is_new ? 'Créer le module' : 'Enregistrer' }}
            </button>
            {% if not is_new %}
                <a href="{{ path('admin_question_index', {formationId: formation.id, id: module.id}) }}"
                   class="bg-gray-100 text-gray-700 px-5 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition">
                    Questions ({{ module.questions|length }})
                </a>
            {% endif %}
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
