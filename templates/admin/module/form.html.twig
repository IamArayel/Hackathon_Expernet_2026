{% extends 'admin/base.html.twig' %}

{% set is_new = module.id is null %}
{% block title %}{{ is_new ? 'Nouveau module' : 'Éditer ' ~ module.title }}{% endblock %}
{% block page_title %}{{ is_new ? 'Nouveau module' : 'Éditer ' ~ module.title }}{% endblock %}

{% block body %}
<div class="flex items-center gap-2 mb-5 text-sm">
    <a href="{{ path('admin_formation_index') }}" class="text-gray-500 hover:text-lava transition">Formations</a>
    <span class="text-gray-700">/</span>
    <a href="{{ path('admin_module_index', {id: formation.id}) }}" class="text-gray-500 hover:text-lava transition">{{ formation.title }}</a>
    <span class="text-gray-700">/</span>
    <span class="text-gray-600">{{ is_new ? 'Nouveau module' : module.title }}</span>
</div>

<div class="max-w-2xl">
    <div class="card-volcanic rounded-2xl p-7">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

        <div class="symfony-form-field">
            {{ form_label(form.title, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.title) }}
            {{ form_errors(form.title) }}
        </div>

        <div class="symfony-form-field" style="max-width: 8rem">
            {{ form_label(form.position, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.position) }}
            {{ form_errors(form.position) }}
        </div>

        <div class="symfony-form-field">
            {{ form_label(form.content, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.content) }}
            {{ form_errors(form.content) }}
        </div>

        <div class="divider-lava"></div>

        <div class="flex gap-3">
            <button type="submit"
                    class="bg-lava text-white px-6 py-2.5 rounded-xl text-sm font-bold hover:bg-[#d44d1b] transition lava-glow-sm"
                    style="font-family:'Poppins',sans-serif">
                {{ is_new ? 'Créer le module' : 'Enregistrer' }}
            </button>
            {% if not is_new %}
                <a href="{{ path('admin_question_index', {formationId: formation.id, id: module.id}) }}"
                   class="bg-smoke text-gray-400 border border-cinder px-6 py-2.5 rounded-xl text-sm font-medium hover:text-lava hover:border-lava/40 transition">
                    Questions ({{ module.questions|length }})
                </a>
            {% endif %}
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
