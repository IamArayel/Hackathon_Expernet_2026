{% extends 'admin/base.html.twig' %}

{% set is_new = formation.id is null %}
{% block title %}{{ is_new ? 'Nouvelle formation' : 'Éditer ' ~ formation.title }}{% endblock %}
{% block page_title %}{{ is_new ? 'Nouvelle formation' : 'Éditer ' ~ formation.title }}{% endblock %}

{% block body %}
<div class="max-w-xl">
    <a href="{{ path('admin_formation_index') }}" class="text-sm text-indigo-600 hover:underline">&larr; Retour aux formations</a>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 mt-4 p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}

        <div>
            {{ form_label(form.title, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.title, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
            {{ form_errors(form.title) }}
        </div>

        <div>
            {{ form_label(form.description, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.description, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                {{ form_label(form.category, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.category, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
                {{ form_errors(form.category) }}
            </div>
            <div>
                {{ form_label(form.difficulty, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.difficulty, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
                {{ form_errors(form.difficulty) }}
            </div>
        </div>

        <div class="pt-2 flex gap-3">
            <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition">
                {{ is_new ? 'Créer la formation' : 'Enregistrer' }}
            </button>
            {% if not is_new %}
                <a href="{{ path('admin_module_index', {id: formation.id}) }}"
                   class="bg-gray-100 text-gray-700 px-5 py-2 rounded-lg text-sm font-medium hover:bg-gray-200 transition">
                    Gérer les modules ({{ formation.modules|length }})
                </a>
            {% endif %}
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
