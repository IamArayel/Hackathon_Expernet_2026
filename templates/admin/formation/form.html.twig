{% extends 'admin/base.html.twig' %}

{% set is_new = formation.id is null %}
{% block title %}{{ is_new ? 'Nouvelle formation' : 'Éditer ' ~ formation.title }}{% endblock %}
{% block page_title %}{{ is_new ? 'Nouvelle formation' : 'Éditer ' ~ formation.title }}{% endblock %}

{% block body %}
<div class="max-w-xl">
    <a href="{{ path('admin_formation_index') }}" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-lava transition mb-5">
        ← Formations
    </a>

    <div class="card-volcanic rounded-2xl p-7">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

        <div class="symfony-form-field">
            {{ form_label(form.title, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.title) }}
            {{ form_errors(form.title) }}
        </div>

        <div class="symfony-form-field">
            {{ form_label(form.description, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="symfony-form-field">
                {{ form_label(form.category, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
                {{ form_widget(form.category) }}
                {{ form_errors(form.category) }}
            </div>
            <div class="symfony-form-field">
                {{ form_label(form.difficulty, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
                {{ form_widget(form.difficulty) }}
                {{ form_errors(form.difficulty) }}
            </div>
        </div>

        <div class="divider-lava"></div>

        <div class="flex gap-3">
            <button type="submit"
                    class="bg-lava text-white px-6 py-2.5 rounded-xl text-sm font-bold hover:bg-[#d44d1b] transition lava-glow-sm"
                    style="font-family:'Poppins',sans-serif">
                {{ is_new ? 'Créer la formation' : 'Enregistrer' }}
            </button>
            {% if not is_new %}
                <a href="{{ path('admin_module_index', {id: formation.id}) }}"
                   class="bg-smoke text-gray-400 border border-cinder px-6 py-2.5 rounded-xl text-sm font-medium hover:text-lava hover:border-lava/40 transition">
                    Gérer les modules ({{ formation.modules|length }})
                </a>
            {% endif %}
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
