{% extends 'admin/base.html.twig' %}

{% block title %}Formations{% endblock %}
{% block page_title %}Formations{% endblock %}

{% block body %}
<div class="flex justify-end mb-5">
    <a href="{{ path('admin_formation_new') }}"
       class="bg-lava text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-[#d44d1b] transition lava-glow-sm"
       style="font-family:'Poppins',sans-serif">
        + Nouvelle formation
    </a>
</div>

<div class="card-volcanic rounded-2xl overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-cinder">
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Titre</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Catégorie</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Difficulté</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Modules</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Créée le</th>
                <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-widest text-gray-600">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-smoke">
            {% set difficulty_labels = {beginner: 'Débutant', intermediate: 'Intermédiaire', advanced: 'Avancé'} %}
            {% for formation in formations %}
            <tr class="hover:bg-smoke transition">
                <td class="px-6 py-3 font-medium text-gray-200">{{ formation.title }}</td>
                <td class="px-6 py-3 text-gray-600">{{ formation.category ?: '—' }}</td>
                <td class="px-6 py-3">
                    <span class="text-xs px-2.5 py-1 rounded-full font-semibold
                        {% if formation.difficulty == 'beginner' %}text-green-400 bg-green-400/10
                        {% elseif formation.difficulty == 'intermediate' %}text-yellow-400 bg-yellow-400/10
                        {% else %}text-red-400 bg-red-400/10{% endif %}">
                        {{ difficulty_labels[formation.difficulty] ?? formation.difficulty }}
                    </span>
                </td>
                <td class="px-6 py-3 text-gray-500">{{ formation.modules|length }}</td>
                <td class="px-6 py-3 text-gray-600">{{ formation.createdAt|date('d/m/Y') }}</td>
                <td class="px-6 py-3 text-right">
                    <div class="flex justify-end gap-2">
                        <a href="{{ path('admin_module_index', {id: formation.id}) }}"
                           class="text-xs bg-smoke text-gray-400 border border-cinder px-3 py-1.5 rounded-lg hover:text-lava hover:border-lava/40 transition">
                            Modules
                        </a>
                        <a href="{{ path('admin_formation_edit', {id: formation.id}) }}"
                           class="text-xs bg-lava/10 text-lava border border-lava/25 px-3 py-1.5 rounded-lg hover:bg-lava/20 transition">
                            Éditer
                        </a>
                        <form method="post" action="{{ path('admin_formation_delete', {id: formation.id}) }}"
                              onsubmit="return confirm('Supprimer « {{ formation.title }} » et tous ses modules ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_formation_' ~ formation.id) }}">
                            <button class="text-xs bg-red-900/20 text-red-400 border border-red-800/40 px-3 py-1.5 rounded-lg hover:bg-red-900/40 transition">
                                Supprimer
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="px-6 py-12 text-gray-600 text-center">Aucune formation</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
