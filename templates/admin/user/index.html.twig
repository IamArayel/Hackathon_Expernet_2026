{% extends 'admin/base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}
{% block page_title %}Utilisateurs{% endblock %}

{% block body %}
<div class="card-volcanic rounded-2xl overflow-hidden">
    <div class="px-6 py-4 border-b border-cinder flex items-center justify-between">
        <span class="text-sm text-gray-600">{{ users|length }} utilisateur(s)</span>
    </div>
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-smoke">
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Utilisateur</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Email</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Rôles</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Niveau / XP</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Inscrit le</th>
                <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-widest text-gray-600">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-smoke">
            {% for user in users %}
            <tr class="hover:bg-smoke transition">
                <td class="px-6 py-3 font-medium text-gray-200">{{ user.username }}</td>
                <td class="px-6 py-3 text-gray-500">{{ user.email }}</td>
                <td class="px-6 py-3">
                    {% for role in user.roles %}
                        {% if role != 'ROLE_USER' %}
                            <span class="bg-lava/10 text-lava border border-lava/25 text-xs px-2.5 py-0.5 rounded-full font-semibold">
                                {{ role }}
                            </span>
                        {% endif %}
                    {% endfor %}
                </td>
                <td class="px-6 py-3">
                    <span class="text-lava font-bold">Niv. {{ user.level }}</span>
                    <span class="text-gray-600 ml-1">— {{ user.xp }} XP</span>
                </td>
                <td class="px-6 py-3 text-gray-600">{{ user.createdAt|date('d/m/Y') }}</td>
                <td class="px-6 py-3 text-right">
                    <div class="flex justify-end gap-2">
                        <a href="{{ path('admin_user_edit', {id: user.id}) }}"
                           class="text-xs bg-lava/10 text-lava border border-lava/25 px-3 py-1.5 rounded-lg hover:bg-lava/20 transition">
                            Éditer
                        </a>
                        {% if user != app.user %}
                        <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}"
                              onsubmit="return confirm('Supprimer {{ user.username }} ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                            <button class="text-xs bg-red-900/20 text-red-400 border border-red-800/40 px-3 py-1.5 rounded-lg hover:bg-red-900/40 transition">
                                Supprimer
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="px-6 py-12 text-gray-600 text-center">Aucun utilisateur</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
