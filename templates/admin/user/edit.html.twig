{% extends 'admin/base.html.twig' %}

{% block title %}Éditer {{ user.username }}{% endblock %}
{% block page_title %}Éditer {{ user.username }}{% endblock %}

{% block body %}
<div class="max-w-xl">
    <a href="{{ path('admin_user_index') }}" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-lava transition mb-5">
        ← Utilisateurs
    </a>

    <div class="card-volcanic rounded-2xl p-7">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

        {% for field in form %}
            <div>
                {{ form_label(field, null, {label_attr: {class: 'block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2'}}) }}
                {% if field.vars.compound %}
                    <div class="space-y-2 mt-1">
                        {% for choice in field %}
                            <label class="flex items-center gap-2.5 text-sm text-gray-400 cursor-pointer hover:text-gray-200 transition">
                                {{ form_widget(choice, {attr: {class: 'accent-lava'}}) }}
                                {{ choice.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="symfony-form-field">
                        {{ form_widget(field) }}
                    </div>
                {% endif %}
                {{ form_errors(field) }}
            </div>
        {% endfor %}

        <div class="divider-lava"></div>

        <button type="submit"
                class="bg-lava text-white px-6 py-2.5 rounded-xl text-sm font-bold hover:bg-[#d44d1b] transition lava-glow-sm"
                style="font-family:'Poppins',sans-serif">
            Enregistrer
        </button>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
