{% extends 'admin/base.html.twig' %}

{% block title %}Éditer {{ user.username }}{% endblock %}
{% block page_title %}Éditer {{ user.username }}{% endblock %}

{% block body %}
<div class="max-w-xl">
    <a href="{{ path('admin_user_index') }}" class="text-sm text-indigo-600 hover:underline">&larr; Retour aux utilisateurs</a>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 mt-4 p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}

        {% for field in form %}
            <div>
                {{ form_label(field, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {% if field.vars.compound %}
                    <div class="space-y-1">
                        {% for choice in field %}
                            <label class="flex items-center gap-2 text-sm">
                                {{ form_widget(choice) }}
                                {{ choice.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                {% else %}
                    {{ form_widget(field, {attr: {class: 'w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500'}}) }}
                {% endif %}
                {{ form_errors(field) }}
            </div>
        {% endfor %}

        <div class="pt-2">
            <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-indigo-700 transition">
                Enregistrer
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
