<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Academ'Île{% endblock %}</title>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body class="min-h-screen bg-gray-50 text-gray-900">

    <nav class="bg-indigo-700 text-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
            <a href="{{ path('home') }}" class="text-xl font-bold tracking-tight">Academ'Île</a>
            <div class="flex items-center gap-6 text-sm font-medium">
                <a href="{{ path('formation_index') }}" class="hover:text-indigo-200 transition">Formations</a>
                <a href="{{ path('leaderboard_index') }}" class="hover:text-indigo-200 transition">Classement</a>
                <a href="{{ path('chatbot_index') }}" class="hover:text-indigo-200 transition">Assistant IA</a>
                {% if app.user %}
                    <span class="text-indigo-200">{{ app.user.username }}</span>
                    <span class="bg-indigo-500 rounded-full px-2 py-0.5 text-xs">
                        Niv. {{ app.user.level }} — {{ app.user.xp }} XP
                    </span>
                    <a href="{{ path('auth_logout') }}" class="hover:text-red-300 transition">Déconnexion</a>
                {% else %}
                    <a href="{{ path('auth_login') }}" class="hover:text-indigo-200 transition">Connexion</a>
                    <a href="{{ path('auth_register') }}" class="bg-white text-indigo-700 rounded px-3 py-1 hover:bg-indigo-50 transition">S'inscrire</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 py-8">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 rounded-lg px-4 py-3 text-sm font-medium
                    {% if type == 'success' %}bg-green-100 text-green-800
                    {% elseif type == 'error' %}bg-red-100 text-red-800
                    {% else %}bg-blue-100 text-blue-800{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

</body>
</html>
