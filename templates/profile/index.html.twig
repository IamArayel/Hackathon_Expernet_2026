{% extends 'base.html.twig' %}

{% block title %}Profil de {{ user.username }} — Academ'Île{% endblock %}

{% block body %}
<style>
    .profile-card {
        background: rgba(15, 15, 15, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(241, 90, 34, 0.15);
    }
    .xp-bar-inner {
        box-shadow: 0 0 15px rgba(241, 90, 34, 0.6);
        background: linear-gradient(90deg, #f15a22, #ff8a50);
    }
    .badge-slot {
        background: rgba(255, 255, 255, 0.03);
        border: 1px dashed rgba(241, 90, 34, 0.2);
    }
</style>

<div class="max-w-5xl mx-auto py-10 px-4">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        {# Colonne de gauche : Avatar et Infos de base #}
        <div class="lg:col-span-1 space-y-6">
            <div class="profile-card rounded-3xl p-8 text-center">
                <div class="relative inline-block mb-4">
                    <div class="w-32 h-32 rounded-2xl bg-magma border-2 border-lava flex items-center justify-center text-5xl overflow-hidden mx-auto shadow-lava">
                        {% if user.avatar %}
                            <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="Avatar" class="w-full h-full object-cover">
                        {% else %}
                            🌋
                        {% endif %}
                    </div>
                    <div class="absolute -bottom-2 -right-2 bg-lava text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
                        LVL {{ user.level }}
                    </div>
                </div>
                
                <h2 class="text-2xl font-bold text-white">{{ user.username }}</h2>
                <p class="text-gray-500 text-sm mb-6">{{ user.email }}</p>
                
                <div class="flex justify-center gap-4 py-4 border-t border-white/5">
                    <div class="text-center">
                        <span class="block text-lava font-bold text-xl">{{ user.streak }}</span>
                        <span class="text-[10px] uppercase text-gray-500 tracking-widest">Série (J)</span>
                    </div>
                    <div class="w-px h-10 bg-white/5"></div>
                    <div class="text-center">
                        <span class="block text-lava font-bold text-xl">{{ user.xp }}</span>
                        <span class="text-[10px] uppercase text-gray-500 tracking-widest">Total XP</span>
                    </div>
                </div>

                <a href="#" class="block w-full mt-4 py-3 rounded-xl border border-gray-800 text-gray-400 hover:text-white hover:border-lava transition-all text-sm font-medium">
                    Modifier le profil
                </a>
            </div>
        </div>

        {# Colonne de droite : Stats et Progression #}
        <div class="lg:col-span-2 space-y-6">
            
            {# Progression du Niveau #}
            <div class="profile-card rounded-3xl p-8">
                <div class="flex justify-between items-end mb-4">
                    <div>
                        <h3 class="text-white font-bold text-lg">Progression</h3>
                        <p class="text-gray-500 text-xs">Plus que quelques efforts pour le niveau {{ user.level + 1 }}</p>
                    </div>
                    <span class="text-lava font-mono font-bold">{{ user.xp % 1000 }} / 1000 XP</span>
                </div>
                <div class="w-full h-4 bg-gray-900 rounded-full overflow-hidden border border-white/5 p-1">
                    <div class="xp-bar-inner h-full rounded-full transition-all duration-1000" style="width: {{ xp_percentage }}%"></div>
                </div>
            </div>

            {# Badges #}
            <div class="profile-card rounded-3xl p-8">
                <h3 class="text-white font-bold text-lg mb-6 flex items-center gap-2">
                    <span class="text-lava">🏆</span> Succès Débloqués
                </h3>
                <div class="grid grid-cols-4 sm:grid-cols-6 gap-4">
                    {% for badge in user.badges %}
                        <div class="group relative">
                            <div class="aspect-square rounded-xl bg-lava/10 border border-lava/20 flex items-center justify-center text-2xl transition-transform group-hover:scale-110 shadow-sm" title="{{ badge.name }}">
                                {{ badge.icon|default('⭐') }}
                            </div>
                        </div>
                    {% else %}
                        {% for i in 1..6 %}
                            <div class="badge-slot aspect-square rounded-xl flex items-center justify-center text-gray-800 text-xl">
                                🔒
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
            </div>

            {# Activité Récente (Modules) #}
            <div class="profile-card rounded-3xl p-8">
                <h3 class="text-white font-bold text-lg mb-6">Modules en cours</h3>
                <div class="space-y-4">
                    {% for progress in user.progress|slice(0, 3) %}
                        <div class="flex items-center justify-between p-4 rounded-2xl bg-white/5 border border-white/5">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-lg bg-magma flex items-center justify-center text-lava border border-lava/20">
                                    {{ progress.completed ? '✅' : '🔥' }}
                                </div>
                                <div>
                                    <h4 class="text-white text-sm font-semibold">{{ progress.module.title }}</h4>
                                    <p class="text-gray-500 text-[11px]">Démarré le {{ progress.startedAt|date('d/m/Y') }}</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <span class="block text-white font-bold text-sm">{{ progress.score }}%</span>
                                <span class="text-[10px] text-gray-500 uppercase">{{ progress.completed ? 'Terminé' : 'En cours' }}</span>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-center text-gray-600 text-sm py-4 italic">Aucune activité pour le moment. Explorez l'île !</p>
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}