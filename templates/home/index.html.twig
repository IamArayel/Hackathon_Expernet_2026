{% extends 'base.html.twig' %}
{% block title %}Accueil — Academ'Île{% endblock %}

{% block body %}

{# ——— HERO ——— #}
<div class="hero-volcanic relative overflow-hidden -mx-4 px-4 sm:-mx-6 sm:px-6 py-16 sm:py-24 text-center mb-2">
    <div class="inline-block bg-lava/10 border border-lava/30 text-lava text-xs font-semibold px-5 py-2 rounded-full mb-8 tracking-widest uppercase">
        🌋 &nbsp; Île de la Réunion · Apprendre autrement
    </div>
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold mb-5 leading-tight" style="font-family:'Poppins',sans-serif">
        Le savoir s'éveille<br>
        <span class="text-lava">comme un volcan</span>
    </h1>
    <p class="text-gray-500 text-base sm:text-lg max-w-lg mx-auto mb-10 leading-relaxed px-2">
        Des parcours de formation générés par l'IA. Progressez module par module, gagnez de l'XP et montez en niveau.
    </p>

    {% if not app.user %}
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 px-4">
            <a href="{{ path('auth_register') }}"
               class="w-full sm:w-auto bg-lava hover:bg-[#d44d1b] text-white px-9 py-4 rounded-xl font-bold transition lava-glow text-center"
               style="font-family:'Poppins',sans-serif">
                Commencer l'aventure
            </a>
            <a href="{{ path('formation_index') }}"
               class="w-full sm:w-auto border border-cinder text-gray-400 hover:border-lava hover:text-lava px-9 py-4 rounded-xl font-semibold transition text-center">
                Voir les formations
            </a>
        </div>
    {% else %}
        <div class="inline-flex items-center gap-3 bg-[#141414] border border-cinder rounded-full px-6 py-2.5">
            <span class="text-lava font-bold" style="font-family:'Poppins',sans-serif">{{ completedCount }} module(s) complété(s)</span>
            <span class="text-gray-700">·</span>
            <a href="{{ path('formation_index') }}" class="text-gray-400 hover:text-lava transition text-sm">Continuer →</a>
        </div>
    {% endif %}
</div>

{# ——— STATS BAR ——— #}
<div class="divider-lava my-0"></div>
<div class="bg-[#0f0f0f] border-b border-smoke -mx-4 px-4 sm:-mx-6 sm:px-6 py-8 mb-12">
    <div class="max-w-lg mx-auto grid grid-cols-3 gap-6 text-center">
        <div>
            <div class="text-3xl font-bold text-lava" style="font-family:'Poppins',sans-serif">{{ formations|length }}</div>
            <div class="text-gray-600 text-xs mt-1 uppercase tracking-wider">Formations</div>
        </div>
        <div class="border-x border-[#1e1e1e]">
            <div class="text-3xl font-bold text-lava" style="font-family:'Poppins',sans-serif">∞</div>
            <div class="text-gray-600 text-xs mt-1 uppercase tracking-wider">Modules IA</div>
        </div>
        <div>
            <div class="text-3xl font-bold text-lava" style="font-family:'Poppins',sans-serif">XP</div>
            <div class="text-gray-600 text-xs mt-1 uppercase tracking-wider">Gamification</div>
        </div>
    </div>
</div>

{# ——— FORMATIONS GRID ——— #}
{% if formations %}
    <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold" style="font-family:'Poppins',sans-serif">Formations disponibles</h2>
        <a href="{{ path('formation_index') }}" class="text-lava text-sm font-semibold hover:underline">Tout voir →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {% for formation in formations %}
            <a href="{{ path('formation_show', {id: formation.id}) }}"
               class="card-volcanic rounded-2xl p-6 block group">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full
                        {% if formation.difficulty == 'beginner' %}text-green-400 bg-green-400/10
                        {% elseif formation.difficulty == 'intermediate' %}text-yellow-400 bg-yellow-400/10
                        {% else %}text-red-400 bg-red-400/10{% endif %}">
                        {{ formation.difficulty }}
                    </span>
                    {% if formation.category %}
                        <span class="text-xs text-gray-700">{{ formation.category }}</span>
                    {% endif %}
                </div>
                <h3 class="font-bold text-lg text-white group-hover:text-lava transition" style="font-family:'Poppins',sans-serif">
                    {{ formation.title }}
                </h3>
                {% if formation.description %}
                    <p class="text-gray-600 text-sm mt-2 line-clamp-2">{{ formation.description }}</p>
                {% endif %}
                <div class="mt-5 flex items-center justify-between">
                    <span class="text-xs text-gray-700">{{ formation.modules|length }} module(s)</span>
                    <span class="text-lava text-xs font-semibold group-hover:translate-x-1 transition-transform inline-block">Commencer →</span>
                </div>
            </a>
        {% endfor %}
    </div>
{% else %}
    <div class="text-center py-24">
        <div class="text-5xl mb-4">🌋</div>
        <p class="text-gray-600">Aucune formation disponible pour le moment.</p>
    </div>
{% endif %}

{% endblock %}
