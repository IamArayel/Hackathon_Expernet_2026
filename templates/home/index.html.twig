{% extends 'base.html.twig' %}
{% block title %}Accueil — Academ'Île{% endblock %}

{% block body %}
<div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-indigo-700 mb-3">Bienvenue sur Academ'Île</h1>
    <p class="text-gray-500 text-lg">Apprenez à votre rythme, progressez et montez en niveau.</p>
    {% if not app.user %}
        <a href="{{ path('auth_register') }}"
           class="mt-6 inline-block bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition">
            Commencer gratuitement
        </a>
    {% else %}
        <p class="mt-4 text-indigo-600 font-medium">
            Modules complétés : {{ completedCount }}
        </p>
    {% endif %}
</div>

{% if formations %}
    <h2 class="text-2xl font-semibold mb-6">Formations disponibles</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for formation in formations %}
            <a href="{{ path('formation_show', {id: formation.id}) }}"
               class="block bg-white rounded-xl shadow hover:shadow-md transition p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-semibold uppercase tracking-wide
                        {% if formation.difficulty == 'beginner' %}text-green-600
                        {% elseif formation.difficulty == 'intermediate' %}text-yellow-600
                        {% else %}text-red-600{% endif %}">
                        {{ formation.difficulty }}
                    </span>
                    {% if formation.category %}
                        <span class="text-xs text-gray-400">{{ formation.category }}</span>
                    {% endif %}
                </div>
                <h3 class="font-bold text-lg text-gray-800">{{ formation.title }}</h3>
                {% if formation.description %}
                    <p class="text-gray-500 text-sm mt-1 line-clamp-2">{{ formation.description }}</p>
                {% endif %}
                <p class="mt-3 text-xs text-gray-400">{{ formation.modules|length }} module(s)</p>
            </a>
        {% endfor %}
    </div>
{% else %}
    <p class="text-center text-gray-400 mt-12">Aucune formation disponible pour le moment.</p>
{% endif %}
{% endblock %}
