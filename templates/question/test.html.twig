<div class="min-h-screen bg-gray-100 flex flex-col items-center justify-center p-4">
    <!-- Card Principale -->
    <div id="quiz-container" class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-2xl">
        
        <!-- État 1 : Chargement / Accueil -->
        <div id="loading-state" class="text-center">
            <h1 class="text-3xl font-bold text-indigo-600 mb-4">Évaluateur IA</h1>
            <p class="text-gray-600 mb-8" id="status-text">Préparation de vos questions personnalisées...</p>
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600 mx-auto"></div>
        </div>

        <!-- État 2 : Le Quiz (Caché au début) -->
        <div id="quiz-state" class="hidden">
            <div class="flex justify-between items-center mb-6">
                <span id="question-counter" class="text-sm font-semibold text-gray-500 uppercase tracking-widest">Question 1/5</span>
                <span id="timer" class="text-indigo-600 font-mono font-bold text-xl">15s</span>
            </div>

            <h2 id="question-text" class="text-xl font-semibold text-gray-800 mb-6">
                <!-- Texte de la question injecté par JS -->
            </h2>

            <div id="answers-grid" class="grid grid-cols-1 gap-4">
                <!-- Boutons de réponses injectés par JS -->
                <!-- Exemple de bouton : 
                <button class="w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-all">Réponse A</button>
                -->
            </div>
        </div>

        <!-- État 3 : Résultat final (Caché) -->
        <div id="result-state" class="hidden text-center">
            <h2 class="text-4xl font-bold text-green-500 mb-2">Terminé !</h2>
            <p class="text-gray-600 mb-6">Votre nouveau score a été enregistré.</p>
            <div class="text-6xl font-black text-gray-800 mb-8" id="final-score">0</div>
            <button onclick="window.location.reload()" class="bg-indigo-600 text-white px-8 py-3 rounded-full font-bold hover:bg-indigo-700">
                Nouvelle Session
            </button>
        </div>
    </div>
</div>

<script>

let currentQuestions = [];
let currentStep = 0;
let userScore = 0;

// 1. Lancer la génération au chargement
async function startQuiz() {
    try {
        const response = await fetch('/quiz/generate', { method: 'POST' });
        const data = await response.json();
        
        console.log("Données reçues :", data); // Ouvre la console (F12) pour vérifier !

        // Correction ici : on vérifie si les questions sont dans data.questions 
        // ou si data est lui-même le tableau
        currentQuestions = data.questions ? data.questions : data;

        if (!currentQuestions || currentQuestions.length === 0) {
            throw new Error("Aucune question reçue");
        }

        showQuestion(0);
        
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('quiz-state').classList.remove('hidden');
    } catch (e) {
        console.error(e);
        document.getElementById('status-text').innerText = "Erreur : " + e.message;
    }
}

// 2. Afficher une question
function showQuestion(index) {
    const q = currentQuestions[index];
    document.getElementById('question-text').innerText = q.question;
    document.getElementById('question-counter').innerText = `Question ${index + 1}/${currentQuestions.length}`;
    
    const grid = document.getElementById('answers-grid');
    grid.innerHTML = ''; // On vide

    q.reponses.forEach((reponse, i) => {
        const btn = document.createElement('button');
        btn.className = "w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-all";
        btn.innerText = reponse;
        btn.onclick = () => handleAnswer(i === q.correct);
        grid.appendChild(btn);
    });
}

// 3. Gérer la réponse
async function handleAnswer(isCorrect) {
    if(isCorrect) userScore += 10;
    
    currentStep++;
    if(currentStep < currentQuestions.length) {
        showQuestion(currentStep);
    } else {
        finishQuiz();
    }
}

// 4. Envoyer le score et afficher la fin
async function finishQuiz() {
    document.getElementById('quiz-state').classList.add('hidden');
    document.getElementById('result-state').classList.remove('hidden');
    document.getElementById('final-score').innerText = `+${userScore}`;

    // Envoi au serveur Symfony
    const formData = new FormData();
    formData.append('points', userScore);
    await fetch('/quiz/submit-score', { method: 'POST', body: formData });
}

startQuiz();

</script>