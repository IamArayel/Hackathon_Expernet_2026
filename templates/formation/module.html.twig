{% extends 'base.html.twig' %}
{% block title %}{{ module.title }} — {{ formation.title }} — Academ'Île{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <a href="{{ path('formation_show', {id: formation.id}) }}"
       class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-lava transition mb-6">
        ← Retour à {{ formation.title }}
    </a>

    {# ——— Module header ——— #}
    <div class="card-volcanic rounded-2xl p-8 mb-6">
        <p class="text-xs text-gray-600 uppercase tracking-widest font-semibold mb-2">{{ formation.title }}</p>
        <h1 class="text-2xl font-bold text-white mb-4" style="font-family:'Poppins',sans-serif">{{ module.title }}</h1>

        {% if progress and progress.completed %}
            <span class="inline-flex items-center gap-2 bg-green-900/30 text-green-400 border border-green-800/50 text-xs font-bold px-4 py-1.5 rounded-full mb-5">
                ✓ Complété — score : {{ progress.score }}%
            </span>
        {% endif %}

        {% if module.content %}
            <div class="divider-lava my-5"></div>
            <div class="text-gray-400 leading-relaxed text-sm prose-invert">
                {{ module.content|nl2br }}
            </div>
        {% endif %}
    </div>

    {# ——— Quiz ——— #}
    {% if module.questions|length > 0 %}
        <div class="card-volcanic rounded-2xl p-8 mb-6">
            <h2 class="text-xl font-bold text-white mb-7" style="font-family:'Poppins',sans-serif">
                Quiz
                <span class="text-gray-600 font-normal text-sm ml-2">{{ module.questions|length }} question(s)</span>
            </h2>

            <form method="post"
                  action="{{ path('formation_module_submit', {id: formation.id, moduleId: module.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('module_submit_' ~ module.id) }}">

                {% for question in module.questions %}
                    <div class="mb-8">
                        <p class="font-semibold text-gray-200 mb-4 leading-snug">
                            <span class="text-lava font-bold mr-2">{{ loop.index }}.</span>{{ question.content }}
                        </p>

                        {% if question.type == 'mcq' and question.options|length > 0 %}
                            <div class="space-y-2">
                                {% for option in question.options %}
                                    <label class="radio-volcanic">
                                        <input type="radio"
                                               name="question_{{ question.id }}"
                                               value="{{ option }}"
                                               {% if progress and progress.completed %}disabled{% endif %}>
                                        <span class="text-gray-300 text-sm">{{ option }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        {% else %}
                            <textarea name="question_{{ question.id }}"
                                      rows="3"
                                      class="input-volcanic resize-none"
                                      placeholder="Votre réponse…"
                                      {% if progress and progress.completed %}disabled{% endif %}></textarea>
                        {% endif %}
                    </div>
                {% endfor %}

                {% if not (progress and progress.completed) %}
                    <div class="divider-lava mb-7"></div>
                    <button type="submit"
                            class="w-full bg-lava text-white font-bold px-6 py-3.5 rounded-xl hover:bg-[#d44d1b] transition lava-glow"
                            style="font-family:'Poppins',sans-serif">
                        Valider mes réponses
                    </button>
                {% endif %}
            </form>
        </div>
    {% endif %}

    {# ——— Navigation entre modules ——— #}
    <div class="flex justify-between items-center pt-2 gap-4">
        {% if prevModule %}
            <a href="{{ path('formation_module_show', {id: formation.id, moduleId: prevModule.id}) }}"
               class="flex items-center gap-2 text-sm text-gray-500 hover:text-lava transition min-w-0">
                <span class="shrink-0">←</span>
                <span class="truncate">{{ prevModule.title }}</span>
            </a>
        {% else %}
            <span></span>
        {% endif %}

        {% if nextModule %}
            <a href="{{ path('formation_module_show', {id: formation.id, moduleId: nextModule.id}) }}"
               class="flex items-center gap-2 text-sm font-bold text-lava hover:underline transition min-w-0 text-right">
                <span class="truncate">{{ nextModule.title }}</span>
                <span class="shrink-0">→</span>
            </a>
        {% else %}
            <a href="{{ path('formation_show', {id: formation.id}) }}"
               class="text-sm font-bold text-green-400 hover:text-green-300 transition shrink-0">
                Fin de la formation →
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}
