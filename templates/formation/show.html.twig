{% extends 'base.html.twig' %}
{% block title %}{{ formation.title }} — Academ'Île{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <a href="{{ path('formation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-lava transition mb-6">
        ← Retour aux formations
    </a>

    {# ——— Formation header card ——— #}
    <div class="card-volcanic rounded-2xl p-8 mb-8">
        <div class="flex items-center gap-3 mb-3">
            <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full
                {% if formation.difficulty == 'beginner' %}text-green-400 bg-green-400/10
                {% elseif formation.difficulty == 'intermediate' %}text-yellow-400 bg-yellow-400/10
                {% else %}text-red-400 bg-red-400/10{% endif %}">
                {{ formation.difficulty }}
            </span>
            {% if formation.category %}
                <span class="text-xs text-gray-600">{{ formation.category }}</span>
            {% endif %}
        </div>

        <h1 class="text-3xl font-bold text-white mb-3" style="font-family:'Poppins',sans-serif">{{ formation.title }}</h1>

        {% if formation.description %}
            <p class="text-gray-500 leading-relaxed">{{ formation.description }}</p>
        {% endif %}

        <div class="divider-lava my-6"></div>

        <form method="post" action="{{ path('formation_start', {id: formation.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('start_' ~ formation.id) }}">
            <button type="submit"
                    class="bg-lava text-white font-semibold px-7 py-3 rounded-xl hover:bg-[#d44d1b] transition lava-glow"
                    style="font-family:'Poppins',sans-serif">
                Commencer la formation
            </button>
        </form>
    </div>

    {# ——— Modules list ——— #}
    <h2 class="text-xl font-bold mb-5" style="font-family:'Poppins',sans-serif">
        Modules <span class="text-gray-600 font-normal text-base">({{ formation.modules|length }})</span>
    </h2>
    <div class="space-y-3">
        {% for module in formation.modules %}
            <a href="{{ path('formation_module_show', {id: formation.id, moduleId: module.id}) }}"
               class="card-volcanic rounded-xl px-5 py-4 flex items-center justify-between group">
                <div class="flex items-center gap-3">
                    <span class="w-7 h-7 rounded-lg bg-smoke border border-cinder flex items-center justify-center text-xs text-gray-500 font-bold shrink-0">
                        {{ loop.index }}
                    </span>
                    <div>
                        <span class="font-medium text-gray-200 group-hover:text-lava transition">{{ module.title }}</span>
                        {% if module.questions|length > 0 %}
                            <span class="ml-2 text-xs text-gray-600">({{ module.questions|length }} question(s))</span>
                        {% endif %}
                    </div>
                </div>
                {% if module.id in completedModuleIds %}
                    <span class="text-green-400 text-xs font-bold">✓ Complété</span>
                {% else %}
                    <span class="text-lava text-xs font-semibold group-hover:translate-x-1 transition-transform inline-block">Accéder →</span>
                {% endif %}
            </a>
        {% else %}
            <p class="text-gray-600 text-sm py-4">Aucun module pour l'instant.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
