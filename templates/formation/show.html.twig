{% extends 'base.html.twig' %}
{% block title %}{{ formation.title }} — Academ'Île{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <a href="{{ path('formation_index') }}" class="text-sm text-indigo-600 hover:underline mb-4 inline-block">← Retour aux formations</a>

    <div class="bg-white rounded-xl shadow p-8 mb-6">
        <div class="flex items-center gap-3 mb-2">
            <span class="text-xs font-semibold uppercase tracking-wide
                {% if formation.difficulty == 'beginner' %}text-green-600
                {% elseif formation.difficulty == 'intermediate' %}text-yellow-600
                {% else %}text-red-600{% endif %}">
                {{ formation.difficulty }}
            </span>
            {% if formation.category %}
                <span class="text-xs text-gray-400">{{ formation.category }}</span>
            {% endif %}
        </div>
        <h1 class="text-3xl font-bold text-gray-900 mb-3">{{ formation.title }}</h1>
        {% if formation.description %}
            <p class="text-gray-600">{{ formation.description }}</p>
        {% endif %}

        <form method="post" action="{{ path('formation_start', {id: formation.id}) }}" class="mt-6">
            <input type="hidden" name="_token" value="{{ csrf_token('start_' ~ formation.id) }}">
            <button type="submit"
                    class="bg-indigo-600 text-white font-semibold px-6 py-2 rounded-lg hover:bg-indigo-700 transition">
                Commencer la formation
            </button>
        </form>
    </div>

    <h2 class="text-xl font-semibold mb-4">Modules ({{ formation.modules|length }})</h2>
    <div class="space-y-3">
        {% for module in formation.modules %}
            <a href="{{ path('formation_module_show', {id: formation.id, moduleId: module.id}) }}"
               class="bg-white rounded-lg shadow-sm border border-gray-100 px-5 py-4 flex items-center justify-between hover:border-indigo-300 hover:shadow transition">
                <div>
                    <span class="text-xs text-gray-400 mr-2">{{ loop.index }}.</span>
                    <span class="font-medium text-gray-800">{{ module.title }}</span>
                    {% if module.questions|length > 0 %}
                        <span class="ml-2 text-xs text-gray-400">({{ module.questions|length }} question(s))</span>
                    {% endif %}
                </div>
                {% if module.id in completedModuleIds %}
                    <span class="text-green-500 text-sm font-semibold">✓ Complété</span>
                {% else %}
                    <span class="text-xs text-indigo-500 font-medium">Accéder →</span>
                {% endif %}
            </a>
        {% else %}
            <p class="text-gray-400 text-sm">Aucun module pour l'instant.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
