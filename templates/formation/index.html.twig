{% extends 'base.html.twig' %}
{% block title %}Formations — Academ'Île{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-indigo-700">Formations</h1>
    <div class="flex gap-3">
        {% for level in ['beginner', 'intermediate', 'advanced'] %}
            <a href="{{ path('formation_index', {difficulty: level}) }}"
               class="text-sm px-3 py-1 rounded-full border transition
                   {{ difficulty == level ? 'bg-indigo-600 text-white border-indigo-600' : 'border-gray-300 text-gray-600 hover:border-indigo-400' }}">
                {{ level }}
            </a>
        {% endfor %}
        <a href="{{ path('formation_index') }}"
           class="text-sm px-3 py-1 rounded-full border border-gray-300 text-gray-600 hover:border-indigo-400 transition">
            Tout
        </a>
    </div>
</div>

{% if formations %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for formation in formations %}
            <a href="{{ path('formation_show', {id: formation.id}) }}"
               class="block bg-white rounded-xl shadow hover:shadow-md transition p-6 border border-gray-100">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-semibold uppercase tracking-wide
                        {% if formation.difficulty == 'beginner' %}text-green-600
                        {% elseif formation.difficulty == 'intermediate' %}text-yellow-600
                        {% else %}text-red-600{% endif %}">
                        {{ formation.difficulty }}
                    </span>
                    {% if formation.category %}
                        <span class="text-xs text-gray-400">{{ formation.category }}</span>
                    {% endif %}
                </div>
                <h2 class="font-bold text-lg text-gray-800">{{ formation.title }}</h2>
                {% if formation.description %}
                    <p class="text-gray-500 text-sm mt-1 line-clamp-2">{{ formation.description }}</p>
                {% endif %}
                <p class="mt-3 text-xs text-gray-400">{{ formation.modules|length }} module(s)</p>
            </a>
        {% endfor %}
    </div>
{% else %}
    <p class="text-center text-gray-400 mt-16">Aucune formation trouvée.</p>
{% endif %}
{% endblock %}
