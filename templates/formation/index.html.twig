{% extends 'base.html.twig' %}
{% block title %}Formations — Academ'Île{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-10">
    <div>
        <h1 class="text-3xl font-bold text-lava" style="font-family:'Poppins',sans-serif">Formations</h1>
        <p class="text-gray-600 text-sm mt-1">Générées et adaptées par IA selon ton profil</p>
    </div>
    <div class="flex gap-2">
        {% for level in ['beginner', 'intermediate', 'advanced'] %}
            <a href="{{ path('formation_index', {difficulty: level}) }}"
               class="text-xs px-4 py-1.5 rounded-full border transition font-medium
                   {{ difficulty == level
                       ? 'bg-lava text-white border-lava lava-glow-sm'
                       : 'border-cinder text-gray-500 hover:border-lava hover:text-lava' }}">
                {{ level }}
            </a>
        {% endfor %}
        <a href="{{ path('formation_index') }}"
           class="text-xs px-4 py-1.5 rounded-full border transition font-medium
               {{ difficulty is not defined or difficulty is null
                   ? 'bg-lava text-white border-lava lava-glow-sm'
                   : 'border-cinder text-gray-500 hover:border-lava hover:text-lava' }}">
            Tout
        </a>
    </div>
</div>

{% if formations %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {% for formation in formations %}
            <a href="{{ path('formation_show', {id: formation.id}) }}"
               class="card-volcanic rounded-2xl p-6 block group">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full
                        {% if formation.difficulty == 'beginner' %}text-green-400 bg-green-400/10
                        {% elseif formation.difficulty == 'intermediate' %}text-yellow-400 bg-yellow-400/10
                        {% else %}text-red-400 bg-red-400/10{% endif %}">
                        {{ formation.difficulty }}
                    </span>
                    {% if formation.category %}
                        <span class="text-xs text-gray-700">{{ formation.category }}</span>
                    {% endif %}
                </div>
                <h2 class="font-bold text-lg text-white group-hover:text-lava transition" style="font-family:'Poppins',sans-serif">
                    {{ formation.title }}
                </h2>
                {% if formation.description %}
                    <p class="text-gray-600 text-sm mt-2 line-clamp-2">{{ formation.description }}</p>
                {% endif %}
                <div class="mt-5 flex items-center justify-between">
                    <span class="text-xs text-gray-700">{{ formation.modules|length }} module(s)</span>
                    <span class="text-lava text-xs font-semibold group-hover:translate-x-1 transition-transform inline-block">Accéder →</span>
                </div>
            </a>
        {% endfor %}
    </div>
{% else %}
    <div class="text-center py-24">
        <div class="text-5xl mb-4">🌋</div>
        <p class="text-gray-600">Aucune formation trouvée.</p>
    </div>
{% endif %}
{% endblock %}
