{% extends 'base.html.twig' %}

{% block body %}
    <h1>Chat avec Mistral (Niveau : {{ conversation.difficulte }})</h1>

    <div id="chat-box" style="border: 1px solid #ccc; height: 300px; overflow-y: scroll; padding: 10px; margin-bottom: 10px;">
        {% for message in conversation.messages %}
            <p><strong>{{ message.role|upper }}:</strong> {{ message.contenu }}</p>
        {% endfor %}
    </div>

    <input type="text" id="user-input" placeholder="Posez votre question..." style="width: 80%">
    <button onclick="sendMessage()">Envoyer</button>

    <script>
        async function sendMessage() {
            const input = document.getElementById('user-input');
            const box = document.getElementById('chat-box');
            const message = input.value;

            box.innerHTML += `<p><strong>USER:</strong> ${message}</p>`;
            input.value = '';

            const response = await fetch('{{ path('app_chat_ask', {id: conversation.id}) }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ 'message': message })
            });

            const data = await response.json();
            box.innerHTML += `<p><strong>ASSISTANT:</strong> ${data.response}</p>`;
            box.scrollTop = box.scrollHeight;
        }
    </script>
{% endblock %}