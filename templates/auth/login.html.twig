{% extends 'base.html.twig' %}
{% block title %}Connexion — Academ'Île{% endblock %}

{% block body %}

{# 🔥 Tailwind config inline (CDN) #}
<script>
tailwind.config = {
    theme: {
        extend: {
            colors: {
                lava: '#f15a22',
                lavaBright: '#ff6b2d',
                ember: '#ff8a50',
                magma: '#2a0d07',
                ash: '#050505',
            },
            boxShadow: {
                lava: '0 0 20px rgba(241, 90, 34, 0.4)',
                lavaStrong: '0 0 40px rgba(241, 90, 34, 0.6)',
            }
        }
    }
}
</script>

<style>
.card-volcanic {
    background: linear-gradient(145deg, #0f0f0f, #080808);
    border: 1px solid #1f1f1f;
    transition: all 0.3s ease;
}

.card-volcanic:hover {
    box-shadow:
        0 0 25px rgba(241, 90, 34, 0.25),
        inset 0 0 20px rgba(241, 90, 34, 0.05);
    border-color: rgba(241, 90, 34, 0.5);
}

.input-volcanic {
    width: 100%;
    background: #0d0d0d;
    border: 1px solid #222;
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    color: white;
    font-size: 0.9rem;
    transition: all 0.25s ease;
}

.input-volcanic:focus {
    outline: none;
    border-color: #f15a22;
    box-shadow: 0 0 0 1px rgba(241, 90, 34, 0.4),
                0 0 15px rgba(241, 90, 34, 0.2);
}

.lava-glow {
    box-shadow:
        0 0 15px rgba(241, 90, 34, 0.4),
        0 0 30px rgba(241, 90, 34, 0.2);
}

.divider-lava {
    background: linear-gradient(90deg, transparent, #f15a22, transparent);
    height: 1px;
}

@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-6px); }
}

.float {
    animation: float 5s ease-in-out infinite;
}

.hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(255,255,255,0.01) 2px,
                rgba(255,255,255,0.01) 4px
            );
            pointer-events: none;
        }
</style>

<div class="hero-bg min-h-[70vh] flex items-center justify-center bg-ash">
    <div class="w-full max-w-md">

        {# Logo + titre #}
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-lava rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5 lava-glow float">
                🌋
            </div>
            <h1 class="text-3xl font-extrabold text-white" style="font-family:'Poppins',sans-serif">
                Connexion
            </h1>
            <p class="text-gray-500 text-sm mt-2">
                Reprenez votre éruption là où vous l'avez laissée
            </p>
        </div>

        <div class="card-volcanic rounded-2xl p-8">
            {% if error %}
                <div class="mb-5 rounded-xl px-4 py-3 bg-red-900/30 text-red-400 border border-red-800/50 text-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" class="space-y-5">
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        Email
                    </label>
                    <input type="email" name="email" value="{{ last_username }}" required autofocus
                           class="input-volcanic">
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        Mot de passe
                    </label>
                    <input type="password" name="password" required
                           class="input-volcanic">
                </div>

                <label class="flex items-center gap-2.5 text-sm text-gray-500 cursor-pointer">
                    <input type="checkbox" name="_remember_me" class="accent-lava rounded">
                    Se souvenir de moi
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="divider-lava"></div>

                <button type="submit"
                        class="w-full bg-lava hover:bg-[#ff6b2d] text-white font-bold py-3.5 rounded-xl transition lava-glow hover:shadow-lavaStrong active:scale-95"
                        style="font-family:'Poppins',sans-serif">
                    Se connecter
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-gray-600">
                Pas encore de compte ?
                <a href="{{ path('auth_register') }}" class="text-lava hover:text-[#ff6b2d] hover:underline font-semibold">
                    S'inscrire
                </a>
            </p>
        </div>
    </div>
</div>

{% endblock %}