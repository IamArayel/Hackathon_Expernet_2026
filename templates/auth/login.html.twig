{% extends 'base.html.twig' %}
{% block title %}Connexion — Academ'Île{% endblock %}

{% block body %}
<div class="min-h-[70vh] flex items-center justify-center">
    <div class="w-full max-w-md">

        {# Logo + titre #}
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-lava rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5 lava-glow">
                🌋
            </div>
            <h1 class="text-3xl font-extrabold text-white" style="font-family:'Poppins',sans-serif">Connexion</h1>
            <p class="text-gray-600 text-sm mt-2">Reprenez votre éruption là où vous l'avez laissée</p>
        </div>

        <div class="card-volcanic rounded-2xl p-8">
            {% if error %}
                <div class="mb-5 rounded-xl px-4 py-3 bg-red-900/30 text-red-400 border border-red-800/50 text-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" class="space-y-5">
                <div>
                    <label for="email" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Email</label>
                    <input type="email" id="email" name="email" value="{{ last_username }}" required autofocus
                           class="input-volcanic">
                </div>
                <div>
                    <label for="password" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Mot de passe</label>
                    <input type="password" id="password" name="password" required autocomplete="current-password"
                           class="input-volcanic">
                </div>
                <label class="flex items-center gap-2.5 text-sm text-gray-500 cursor-pointer">
                    <input type="checkbox" name="_remember_me" class="accent-lava rounded"> Se souvenir de moi
                </label>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="divider-lava"></div>

                <button type="submit"
                        class="w-full bg-lava text-white font-bold py-3.5 rounded-xl hover:bg-[#d44d1b] transition lava-glow"
                        style="font-family:'Poppins',sans-serif">
                    Se connecter
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-gray-600">
                Pas encore de compte ?
                <a href="{{ path('auth_register') }}" class="text-lava hover:underline font-semibold">S'inscrire</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
