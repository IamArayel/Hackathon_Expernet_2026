{% extends 'base.html.twig' %}
{% block title %}Connexion — Academ'Île{% endblock %}

{% block body %}

<div class="hero-bg min-h-[70vh] flex items-center justify-center bg-ash">
    <div class="w-full max-w-md">

        {# Logo + titre #}
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-lava rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5 lava-glow float">
                🌋
            </div>
            <h1 class="text-3xl font-extrabold text-white" style="font-family:'Poppins',sans-serif">
                Connexion
            </h1>
            <p class="text-gray-500 text-sm mt-2">
                Reprenez votre éruption là où vous l'avez laissée
            </p>
        </div>

        <div class="card-volcanic rounded-2xl p-8">
            {% if error %}
                <div class="mb-5 rounded-xl px-4 py-3 bg-red-900/30 text-red-400 border border-red-800/50 text-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" class="space-y-5">
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        Email
                    </label>
                    <div class="relative">
                        <input type="email" id="login-email" name="email" value="{{ last_username }}" required autofocus
                               class="input-volcanic pr-10">
                        <span id="email-icon" class="field-icon hidden"></span>
                    </div>
                    <p id="email-msg" class="mt-1.5 text-xs hidden"></p>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        Mot de passe
                    </label>
                    <input type="password" id="login-password" name="password" required
                           class="input-volcanic">
                    <ul id="pwd-rules" class="mt-2 space-y-1 hidden">
                        <li id="rule-length"  class="flex items-center gap-1.5 text-xs text-gray-500"><span class="rule-icon">○</span> 12 caractères minimum</li>
                        <li id="rule-upper"   class="flex items-center gap-1.5 text-xs text-gray-500"><span class="rule-icon">○</span> Une majuscule</li>
                        <li id="rule-lower"   class="flex items-center gap-1.5 text-xs text-gray-500"><span class="rule-icon">○</span> Une minuscule</li>
                        <li id="rule-digit"   class="flex items-center gap-1.5 text-xs text-gray-500"><span class="rule-icon">○</span> Un chiffre</li>
                        <li id="rule-special" class="flex items-center gap-1.5 text-xs text-gray-500"><span class="rule-icon">○</span> Un caractère spécial</li>
                    </ul>
                </div>

                <label class="flex items-center gap-2.5 text-sm text-gray-500 cursor-pointer">
                    <input type="checkbox" name="_remember_me" class="accent-lava rounded">
                    Se souvenir de moi
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="divider-lava"></div>

                <button type="submit"
                        class="w-full bg-lava hover:bg-[#ff6b2d] text-white font-bold py-3.5 rounded-xl transition lava-glow hover:shadow-lavaStrong active:scale-95"
                        style="font-family:'Poppins',sans-serif">
                    Se connecter
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-gray-600">
                Pas encore de compte ?
                <a href="{{ path('auth_register') }}" class="text-lava hover:text-[#ff6b2d] hover:underline font-semibold">
                    S'inscrire
                </a>
            </p>
        </div>
    </div>
</div>

<script>
(function () {
    // Email format validation
    const emailInput = document.getElementById('login-email');
    const emailIcon  = document.getElementById('email-icon');
    const emailMsg   = document.getElementById('email-msg');
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    emailInput.addEventListener('input', function () {
        const v = emailInput.value.trim();

        if (!v) {
            emailInput.classList.remove('input-invalid', 'input-valid');
            emailIcon.className = 'field-icon hidden';
            emailMsg.className  = 'mt-1.5 text-xs hidden';
            return;
        }

        if (emailRegex.test(v)) {
            emailInput.classList.remove('input-invalid');
            emailInput.classList.add('input-valid');
            emailIcon.textContent = '✓';
            emailIcon.className   = 'field-icon text-green-400';
            emailMsg.className    = 'mt-1.5 text-xs hidden';
        } else {
            emailInput.classList.remove('input-valid');
            emailInput.classList.add('input-invalid');
            emailIcon.textContent = '✗';
            emailIcon.className   = 'field-icon text-red-400';
            emailMsg.textContent  = 'Adresse email invalide.';
            emailMsg.className    = 'mt-1.5 text-xs text-red-400';
        }
    });

    // Trigger on page load if field is pre-filled (après une tentative de connexion échouée)
    if (emailInput.value.trim()) {
        emailInput.dispatchEvent(new Event('input'));
    }

    // Password strength validation
    const pwdInput = document.getElementById('login-password');
    const pwdRules = document.getElementById('pwd-rules');

    const rules = [
        { id: 'rule-length',  test: function (v) { return v.length >= 12; } },
        { id: 'rule-upper',   test: function (v) { return /[A-Z]/.test(v); } },
        { id: 'rule-lower',   test: function (v) { return /[a-z]/.test(v); } },
        { id: 'rule-digit',   test: function (v) { return /[0-9]/.test(v); } },
        { id: 'rule-special', test: function (v) { return /[\W_]/.test(v); } },
    ];

    pwdInput.addEventListener('input', function () {
        const v = pwdInput.value;

        if (!v) {
            pwdRules.classList.add('hidden');
            pwdInput.classList.remove('input-invalid', 'input-valid');
            return;
        }

        pwdRules.classList.remove('hidden');

        var allOk = true;
        rules.forEach(function (rule) {
            const li   = document.getElementById(rule.id);
            const icon = li.querySelector('.rule-icon');
            const ok   = rule.test(v);
            li.classList.toggle('rule-ok',   ok);
            li.classList.toggle('rule-fail', !ok);
            icon.textContent = ok ? '✓' : '✗';
            if (!ok) allOk = false;
        });

        pwdInput.classList.toggle('input-invalid', !allOk);
        pwdInput.classList.toggle('input-valid',    allOk);
    });
}());
</script>

{% endblock %}