{% extends 'base.html.twig' %}
{% block title %}Inscription — Academ'Île{% endblock %}

{% block body %}
<div class="max-w-md mx-auto mt-10 bg-white rounded-xl shadow p-8">
    <h1 class="text-2xl font-bold text-indigo-700 mb-6 text-center">Créer un compte</h1>

    {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
        {% for field in form %}
            <div>
                {{ form_label(field, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(field, {attr: {class: 'w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500'}}) }}
                {{ form_errors(field) }}
            </div>
        {% endfor %}
        <button type="submit"
                class="w-full bg-indigo-600 text-white font-semibold py-2 rounded-lg hover:bg-indigo-700 transition">
            Créer mon compte
        </button>
    {{ form_end(form) }}

    <p class="mt-4 text-center text-sm text-gray-500">
        Déjà un compte ?
        <a href="{{ path('auth_login') }}" class="text-indigo-600 hover:underline">Se connecter</a>
    </p>
</div>
{% endblock %}
