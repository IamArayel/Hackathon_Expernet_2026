{% extends 'base.html.twig' %}
{% block title %}Inscription — Academ'Île{% endblock %}

{% block body %}
<script>
tailwind.config = {
    theme: {
        extend: {
            colors: {
                lava: '#f15a22',
                lavaBright: '#ff6b2d',
                ember: '#ff8a50',
                magma: '#2a0d07',
                ash: '#050505',
            },
            boxShadow: {
                lava: '0 0 20px rgba(241, 90, 34, 0.4)',
                lavaStrong: '0 0 40px rgba(241, 90, 34, 0.6)',
            }
        }
    }
}
</script>

<style>
.card-volcanic {
    background: linear-gradient(145deg, #0f0f0f, #080808);
    border: 1px solid #1f1f1f;
    transition: all 0.3s ease;
}

.card-volcanic:hover {
    box-shadow:
        0 0 25px rgba(241, 90, 34, 0.25),
        inset 0 0 20px rgba(241, 90, 34, 0.05);
    border-color: rgba(241, 90, 34, 0.5);
}

.input-volcanic {
    width: 100%;
    background: #0d0d0d;
    border: 1px solid #222;
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    color: white;
    font-size: 0.9rem;
    transition: all 0.25s ease;
}

.input-volcanic:focus {
    outline: none;
    border-color: #f15a22;
    box-shadow: 0 0 0 1px rgba(241, 90, 34, 0.4),
                0 0 15px rgba(241, 90, 34, 0.2);
}

.lava-glow {
    box-shadow:
        0 0 15px rgba(241, 90, 34, 0.4),
        0 0 30px rgba(241, 90, 34, 0.2);
}

.divider-lava {
    background: linear-gradient(90deg, transparent, #f15a22, transparent);
    height: 1px;
}

@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-6px); }
}

.float {
    animation: float 5s ease-in-out infinite;
}

.hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(255,255,255,0.01) 2px,
                rgba(255,255,255,0.01) 4px
            );
            pointer-events: none;
        }
</style>

<div class=" hero-bg min-h-[70vh] flex items-center justify-center py-8">
    <div class="w-full max-w-md">

        {# Logo + titre #}
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-lava rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5 lava-glow">
                🌋
            </div>
            <h1 class="text-3xl font-extrabold text-white" style="font-family:'Poppins',sans-serif">Créer un compte</h1>
            <p class="text-gray-600 text-sm mt-2">Rejoignez l'éruption du savoir</p>
        </div>

        <div class="card-volcanic rounded-2xl p-8">
            {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
                {% for field in form %}
                    <div class="symfony-form-field">
                        {{ form_label(field, null, {label_attr: {class: 'block text-xs font-semibold text-white uppercase tracking-wider mb-2'}}) }}
                        {{ form_widget(field) }}
                        {% if form_errors(field) is not empty %}
                            <div class="mt-1.5 text-xs text-red-400">{{ form_errors(field) }}</div>
                        {% endif %}
                    </div>
                {% endfor %}

                <div class="divider-lava"></div>

                <button type="submit"
                        class="w-full bg-lava text-white font-bold py-3.5 rounded-xl hover:bg-[#d44d1b] transition lava-glow"
                        style="font-family:'Poppins',sans-serif">
                    Créer mon compte
                </button>
            {{ form_end(form) }}

            <p class="mt-6 text-center text-sm text-gray-600">
                Déjà un compte ?
                <a href="{{ path('auth_login') }}" class="text-lava hover:underline font-semibold hover:text-[#ff6b2d]">Se connecter</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
