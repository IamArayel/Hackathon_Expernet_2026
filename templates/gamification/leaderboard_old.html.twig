{% extends 'base.html.twig' %}
{% block title %}Classement — Academ'Île{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-10">
    <div>
        <h1 class="text-3xl font-extrabold" style="font-family:'Poppins',sans-serif">
            Classement <span class="text-lava">volcanique</span>
        </h1>
        <p class="text-gray-600 text-sm mt-1">Chaque module complété te rapporte de l'XP. Deviens la légende de l'île.</p>
    </div>
    <div class="text-4xl">🏆</div>
</div>

{# ——— Podium top 3 ——— #}
{% if topUsers|length >= 3 %}
<div class="grid grid-cols-3 gap-4 mb-10">
    {# 2nd place #}
    <div class="card-volcanic rounded-2xl p-6 text-center mt-6">
        <div class="text-3xl mb-2">🥈</div>
        <div class="font-bold text-gray-200 text-sm" style="font-family:'Poppins',sans-serif">{{ topUsers[1].username }}</div>
        <div class="text-gray-600 text-xs mt-1">Niveau {{ topUsers[1].level }}</div>
        <div class="text-gray-300 font-bold mt-2 text-lg">{{ topUsers[1].xp }} XP</div>
    </div>
    {# 1st place #}
    <div class="card-volcanic rounded-2xl p-6 text-center border-lava/40" style="border-color: rgba(241,90,34,0.35); box-shadow: 0 0 28px rgba(241,90,34,0.18);">
        <div class="text-4xl mb-2">🥇</div>
        <div class="font-extrabold text-white text-base" style="font-family:'Poppins',sans-serif">{{ topUsers[0].username }}</div>
        <div class="text-gray-500 text-xs mt-1">Niveau {{ topUsers[0].level }}</div>
        <div class="text-lava font-extrabold mt-2 text-xl">{{ topUsers[0].xp }} XP</div>
        <div class="inline-block bg-lava/10 border border-lava/30 text-lava text-xs px-3 py-1 rounded-full mt-3 font-semibold">#1 Éruption</div>
    </div>
    {# 3rd place #}
    <div class="card-volcanic rounded-2xl p-6 text-center mt-10">
        <div class="text-3xl mb-2">🥉</div>
        <div class="font-bold text-gray-200 text-sm" style="font-family:'Poppins',sans-serif">{{ topUsers[2].username }}</div>
        <div class="text-gray-600 text-xs mt-1">Niveau {{ topUsers[2].level }}</div>
        <div class="text-gray-300 font-bold mt-2 text-lg">{{ topUsers[2].xp }} XP</div>
    </div>
</div>
{% endif %}

{# ——— Full table ——— #}
<div class="card-volcanic rounded-2xl overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-cinder">
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Rang</th>
                <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-widest text-gray-600">Joueur</th>
                <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-widest text-gray-600">Niveau</th>
                <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-widest text-gray-600">XP</th>
                <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-widest text-gray-600">Badges</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-smoke">
            {% for user in topUsers %}
                <tr class="transition
                    {{ currentUser and currentUser.id == user.id
                        ? 'bg-lava/8 border-l-2 border-lava'
                        : 'hover:bg-smoke' }}">
                    <td class="px-6 py-4 text-gray-500 text-base">
                        {% if loop.index == 1 %}🥇
                        {% elseif loop.index == 2 %}🥈
                        {% elseif loop.index == 3 %}🥉
                        {% else %}<span class="font-mono text-gray-600">{{ loop.index }}</span>{% endif %}
                    </td>
                    <td class="px-6 py-4">
                        <span class="font-semibold text-gray-200 {{ currentUser and currentUser.id == user.id ? 'text-lava' : '' }}">
                            {{ user.username }}
                            {% if currentUser and currentUser.id == user.id %}
                                <span class="ml-2 text-xs bg-lava/10 border border-lava/30 text-lava px-2 py-0.5 rounded-full font-bold">Moi</span>
                            {% endif %}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-right text-lava font-bold">{{ user.level }}</td>
                    <td class="px-6 py-4 text-right font-mono text-gray-300">{{ user.xp }}</td>
                    <td class="px-6 py-4 text-right text-gray-600">{{ user.badges|length }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-16 text-center text-gray-600">
                        <div class="text-4xl mb-3">🌋</div>
                        Aucun joueur inscrit pour l'instant.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
