{% extends 'base.html.twig' %}
{% block title %}Classement — Academ'Île{% endblock %}

{% block body %}
<h1 class="text-3xl font-bold text-indigo-700 mb-8">Classement</h1>

<div class="bg-white rounded-xl shadow overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-indigo-50 text-indigo-700 uppercase text-xs tracking-wide">
            <tr>
                <th class="px-6 py-3 text-left">Rang</th>
                <th class="px-6 py-3 text-left">Joueur</th>
                <th class="px-6 py-3 text-right">Niveau</th>
                <th class="px-6 py-3 text-right">XP</th>
                <th class="px-6 py-3 text-right">Badges</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {% for user in topUsers %}
                <tr class="{{ currentUser and currentUser.id == user.id ? 'bg-indigo-50 font-semibold' : 'hover:bg-gray-50' }} transition">
                    <td class="px-6 py-4 text-gray-500">
                        {% if loop.index == 1 %}🥇
                        {% elseif loop.index == 2 %}🥈
                        {% elseif loop.index == 3 %}🥉
                        {% else %}{{ loop.index }}{% endif %}
                    </td>
                    <td class="px-6 py-4 text-gray-800">{{ user.username }}</td>
                    <td class="px-6 py-4 text-right text-indigo-600">{{ user.level }}</td>
                    <td class="px-6 py-4 text-right font-mono">{{ user.xp }}</td>
                    <td class="px-6 py-4 text-right text-gray-500">{{ user.badges|length }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-10 text-center text-gray-400">
                        Aucun joueur inscrit pour l'instant.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
