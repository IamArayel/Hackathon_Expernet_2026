{% extends 'base.html.twig' %}
{% block title %}Classement — Academ'Île{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto py-8">
    
    {# Header #}
    <div class="flex items-end justify-between mb-12">
        <div>
            <span class="text-lava uppercase tracking-[0.3em] text-xs font-bold">Hall of Fame</span>
            <h1 class="text-4xl font-extrabold text-white mt-2" style="font-family:'Poppins',sans-serif">
                Classement <span class="text-lava">volcanique</span>
            </h1>
            <p class="text-gray-600 text-sm mt-1">Chaque module complété te rapporte de l'XP. Deviens la légende de l'île.</p>
            <p class="text-gray-500 text-sm mt-2 italic">"Seuls ceux qui bravent le magma atteignent le sommet."</p>
        </div>
        <div class="hidden md:block text-6xl opacity-20 select-none">🏆</div>
    </div>

    {# ——— Podium top 3 ——— #}
    {% if topUsers|length >= 3 %}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end mb-16 px-4">
        
        {# 2ème Place #}
        <div class="card-volcanic rounded-3xl p-6 text-center order-2 md:order-1 relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-full h-1 bg-gray-400 opacity-30"></div>
            <div class="text-4xl mb-4 grayscale group-hover:grayscale-0 transition-all">🥈</div>
            <div class="w-16 h-16 rounded-full bg-gray-800 mx-auto mb-3 flex items-center justify-center border-2 border-gray-400">
                <span class="text-xl">🌋</span>
            </div>
            <div class="font-bold text-white text-lg">{{ topUsers[1].username }}</div>
            <div class="text-lava font-mono font-bold text-xl mt-1">{{ topUsers[1].xp }} <span class="text-[10px] text-gray-500">XP</span></div>
            <div class="mt-2 text-xs text-gray-500 uppercase tracking-widest">Niveau {{ topUsers[1].level }}</div>
        </div>

        {# 1ère Place (Le ROI) #}
        <div class="podium-1 rounded-3xl p-8 text-center order-1 md:order-2 relative shadow-2xl">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-lava text-white text-xs font-black px-4 py-1 rounded-full shadow-lava animate-pulse">
                LEADER
            </div>
            <div class="text-6xl mb-4 drop-shadow-lg">🥇</div>
            <div class="w-20 h-20 rounded-full bg-magma mx-auto mb-3 flex items-center justify-center border-2 border-lava shadow-lava">
                <span class="text-3xl">🔥</span>
            </div>
            <div class="font-black text-white text-2xl uppercase tracking-tight">{{ topUsers[0].username }}</div>
            <div class="text-lava font-mono font-black text-3xl mt-1 rank-glow">{{ topUsers[0].xp }} <span class="text-[10px] text-gray-400">XP</span></div>
            <div class="mt-3 inline-block bg-lava/20 border border-lava/40 text-lava text-[10px] px-4 py-1 rounded-full font-bold uppercase tracking-tighter">
                Gardien de l'Île
            </div>
        </div>

        {# 3ème Place #}
        <div class="card-volcanic rounded-3xl p-6 text-center order-3 md:order-3 relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-full h-1 bg-orange-900 opacity-30"></div>
            <div class="text-4xl mb-4 grayscale group-hover:grayscale-0 transition-all text-orange-800">🥉</div>
            <div class="w-16 h-16 rounded-full bg-gray-800 mx-auto mb-3 flex items-center justify-center border-2 border-orange-900">
                <span class="text-xl">🗿</span>
            </div>
            <div class="font-bold text-white text-lg">{{ topUsers[2].username }}</div>
            <div class="text-lava font-mono font-bold text-xl mt-1">{{ topUsers[2].xp }} <span class="text-[10px] text-gray-500">XP</span></div>
            <div class="mt-2 text-xs text-gray-500 uppercase tracking-widest">Niveau {{ topUsers[2].level }}</div>
        </div>
    </div>
    {% endif %}

    {# ——— Full table ——— #}
    <div class="card-volcanic rounded-3xl overflow-hidden shadow-2xl border border-white/5">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-white/5 text-gray-500">
                        <th class="px-8 py-5 text-xs font-bold uppercase tracking-[0.2em]">Rang</th>
                        <th class="px-8 py-5 text-xs font-bold uppercase tracking-[0.2em]">Explorateur</th>
                        <th class="px-8 py-5 text-center text-xs font-bold uppercase tracking-[0.2em]">Niveau</th>
                        <th class="px-8 py-5 text-right text-xs font-bold uppercase tracking-[0.2em]">Expérience</th>
                        <th class="px-8 py-5 text-right text-xs font-bold uppercase tracking-[0.2em]">Badges</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    {% for user in topUsers %}
                        {% set isMe = currentUser and currentUser.id == user.id %}
                        <tr class="transition-all duration-300 {{ isMe ? 'table-row-me' : 'hover:bg-white/[0.02]' }}">
                            <td class="px-8 py-5">
                                <div class="flex items-center">
                                    {% if loop.index == 1 %}
                                        <span class="w-8 h-8 rounded-full bg-yellow-500/20 text-yellow-500 flex items-center justify-center font-bold border border-yellow-500/30">1</span>
                                    {% elseif loop.index == 2 %}
                                        <span class="w-8 h-8 rounded-full bg-gray-400/20 text-gray-400 flex items-center justify-center font-bold border border-gray-400/30">2</span>
                                    {% elseif loop.index == 3 %}
                                        <span class="w-8 h-8 rounded-full bg-orange-700/20 text-orange-700 flex items-center justify-center font-bold border border-orange-700/30">3</span>
                                    {% else %}
                                        <span class="w-8 h-8 text-gray-600 flex items-center justify-center font-mono text-sm">{{ loop.index }}</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg bg-gray-900 border border-white/10 flex items-center justify-center text-xs shadow-inner">
                                        {{ user.avatar ? '🖼️' : '👤' }}
                                    </div>
                                    <span class="font-bold {{ isMe ? 'text-white' : 'text-gray-300' }}">
                                        {{ user.username }}
                                        {% if isMe %}
                                            <span class="ml-2 text-[9px] bg-lava text-white px-2 py-0.5 rounded-full uppercase tracking-tighter">Vous</span>
                                        {% endif %}
                                    </span>
                                </div>
                            </td>
                            <td class="px-8 py-5 text-center">
                                <span class="bg-gray-900 text-lava text-xs font-bold px-3 py-1 rounded-lg border border-lava/20">
                                    LVL {{ user.level }}
                                </span>
                            </td>
                            <td class="px-8 py-5 text-right">
                                <span class="font-mono font-bold text-gray-200">{{ user.xp|number_format(0, '.', ' ') }}</span>
                                <span class="text-lava ml-1 text-[10px] font-bold">XP</span>
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex justify-end -space-x-2">
                                    {% for i in 1..min(user.badges|length, 3) %}
                                        <div class="w-6 h-6 rounded-full bg-magma border border-lava/30 flex items-center justify-center text-[10px] shadow-lg">⭐</div>
                                    {% endfor %}
                                    {% if user.badges|length > 3 %}
                                        <div class="w-6 h-6 rounded-full bg-gray-800 border border-white/10 flex items-center justify-center text-[8px] text-gray-400">+{{ user.badges|length - 3 }}</div>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}